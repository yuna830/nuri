# Copy this file to .env.local and fill in local/team values.
# Do not commit .env.local.

# Spring backend.
# Empty uses Vite proxy in local dev. For another PC, set this to the backend PC LAN URL.
# Example: VITE_API_BASE_URL=http://192.168.0.12:8080
VITE_API_BASE_URL=

# Fall detection FastAPI server.
# If one teammate runs C:\fall-detection, use that teammate's LAN IP here.
# Example: VITE_FALL_API_BASE=http://192.168.0.12:8000
VITE_FALL_API_PORT=8000
VITE_FALL_API_BASE=

# Chat FastAPI server
VITE_CHAT_STT_API_URL=
VITE_CHAT_FOOD_API_URL=

# Welfare RAG / AI backend
VITE_AI_API_BASE_URL=

# Optional separate police/missing service. Empty uses Spring backend.
VITE_POLICE_API_BASE_URL=
VITE_WELFARE_API_BASE_URL=



# Kakao
VITE_KAKAO_REST_API_KEY=
VITE_KAKAO_JAVASCRIPT_KEY=

# Public data/weather
VITE_PUBLIC_DATA_SERVICE_KEY=

# Seoul Open Data APIs
VITE_SEOUL_ATTRACTIVE_JOB_KEY=
VITE_SEOUL_PUBLIC_JOB_KEY=
VITE_SEOUL_JOB_INFO_KEY=
VITE_SEOUL_SENIOR_JOB_CENTER_KEY=

# MOLIT senior welfare facility location API
VITE_MOLIT_SENIOR_WELFARE_KEY=

# Gemini/chat
VITE_GEMINI_MODEL=gemini-2.5-flash-lite
VITE_GEMINI_API_KEY=
VITE_GEMINI_STT_FIX_API_KEY=

